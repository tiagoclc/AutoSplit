<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121B22"
    android:orientation="horizontal"
    android:baselineAligned="false"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.6"
        android:orientation="vertical"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AutoSplit"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1E2A32"
                app:cardCornerRadius="14dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:weightSum="6">

                    <ImageView
                        android:id="@+id/img_app1_icon"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.5"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_question_mark" />

                    <TextView
                        android:id="@+id/txt_app1_label"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.5"
                        android:text="App 1 (Esquerda)"
                        android:textColor="#E9EDEF"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:ellipsize="end"
                        android:maxLines="1"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="12sp"
                        app:autoSizeMaxTextSize="24sp"
                        android:layout_marginTop="4dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_select_app1"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="2.5"
                        android:text="Selecionar"
                        android:textColor="#00A884"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="#1E2A32"
                app:cardCornerRadius="14dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:weightSum="6">

                    <ImageView
                        android:id="@+id/img_app2_icon"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.5"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_question_mark" />

                    <TextView
                        android:id="@+id/txt_app2_label"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.5"
                        android:text="App 2 (Direita)"
                        android:textColor="#E9EDEF"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:ellipsize="end"
                        android:maxLines="1"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="12sp"
                        app:autoSizeMaxTextSize="24sp"
                        android:layout_marginTop="4dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_select_app2"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="2.5"
                        android:text="Selecionar"
                        android:textColor="#00A884"
                        android:padding="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>



        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="8dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardBackgroundColor="#1E2A32"
                app:cardCornerRadius="10dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2A3942">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Rodar no boot"
                        android:textColor="#E9EDEF"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_auto_start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/green_byd"
                        app:trackTint="@color/bg_card"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardBackgroundColor="#1E2A32"
                app:cardCornerRadius="10dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2A3942">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Botão Flutuante"
                        android:textColor="#E9EDEF"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_floating_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/green_byd"
                        app:trackTint="@color/bg_card"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_run_automation"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Rodar Agora"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="#00A884"
            app:cornerRadius="25dp"/>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.9"
        app:cardBackgroundColor="#1E2A32"
        app:cardCornerRadius="16dp"
        app:strokeWidth="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status do Sistema"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2A3942"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/txt_system_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• Verificando sistemas..."
                android:textColor="#8696A0"
                android:textSize="13sp"
                android:lineSpacingExtra="6dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
